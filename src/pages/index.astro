<script>
        function toggleDrawer() {
            const drawer = document.getElementById('nav-drawer');
            const overlay = document.getElementById('drawer-overlay');
            const isOpen = !drawer.classList.contains('translate-x-full');
            
            if (isOpen) {
                drawer.classList.add('translate-x-full');
                overlay.classList.add('hidden');
                overlay.classList.remove('opacity-100');
                document.body.classList.remove('overflow-hidden');
            } else {
                drawer.classList.remove('translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.add('opacity-100'), 10);
                document.body.classList.add('overflow-hidden');
            }
        }

        // Header effect on scroll
        window.addEventListener('scroll', () => {
            const header = document.querySelector('header');
            if (window.scrollY > 20) {
                header.classList.add('h-16', 'shadow-md');
                header.classList.remove('h-20', 'shadow-sm');
            } else {
                header.classList.add('h-20', 'shadow-sm');
                header.classList.remove('h-16', 'shadow-md');
            }
        });
    </script>

<script is:inline>
  (async () => {
    const host = window.location.hostname || "";
    const inferredPbUrl = host.startsWith("demo.")
      ? `${window.location.protocol}//pb-${host}`
      : "";
    const baseUrl = (window.POCKETBASE_URL || localStorage.getItem("pb_url") || inferredPbUrl || "").replace(/\/$/, "");
    if (!baseUrl) return;

    const setText = (id, value) => {
      if (!value) return;
      const el = document.getElementById(id);
      if (el) el.textContent = value;
    };
    const mapImageUrl = (base, collection, recordId, filename) => {
      if (!filename || !recordId) return "";
      return `${base}/api/files/${collection}/${recordId}/${filename}`;
    };
    const getEmbedMapUrl = (mapsUrl, address) => {
      const value = (mapsUrl || "").trim();
      if (!value) return "";
      try {
        const u = new URL(value);
        const host = u.hostname.toLowerCase();
        const allowed = host.includes("google.com") || host.includes("maps.app.goo.gl") || host.includes("goo.gl");
        if (!allowed) return "";
        if (u.pathname.includes("/maps/embed")) return value;
        const q = u.searchParams.get("q");
        if (q) return `https://www.google.com/maps?q=${encodeURIComponent(q)}&output=embed`;
        const coordMatch = `${u.pathname}${u.search}`.match(/@(-?\d+(?:\.\d+)?),(-?\d+(?:\.\d+)?)/);
        if (coordMatch) {
          const lat = coordMatch[1];
          const lng = coordMatch[2];
          return `https://www.google.com/maps?q=${lat},${lng}&output=embed`;
        }
        const query = (address || "").trim();
        if (query) return `https://www.google.com/maps?q=${encodeURIComponent(query)}&output=embed`;
        return "";
      } catch (_) {
        return "";
      }
    };

    try {
      const settingsRes = await fetch(`${baseUrl}/api/collections/site_settings/records?page=1&perPage=1&sort=-created`);
      if (settingsRes.ok) {
        const settingsJson = await settingsRes.json();
        const settings = settingsJson?.items?.[0];
        if (settings) {
          setText("hero-title", settings.hero_title);
          setText("hero-subtitle", settings.hero_subtitle);
          setText("contact-address", settings.address);
          if (settings.phone) {
            setText("contact-phone", `Teléfono: ${settings.phone}`);
          }
          const mapLink = document.getElementById("contact-map-link");
          const mapImage = document.getElementById("map-image");
          const mapEmbed = document.getElementById("map-embed");
          const mapOverlay = document.getElementById("map-overlay");
          const mapPin = document.getElementById("map-pin");
          const mapEmbedUrl = getEmbedMapUrl(settings.maps_url, settings.address);
          if (mapLink && settings.maps_url) {
            mapLink.classList.remove("hidden");
            mapLink.setAttribute("href", settings.maps_url);
          }
          if (mapEmbed && mapImage && mapEmbedUrl) {
            mapEmbed.classList.remove("hidden");
            mapEmbed.setAttribute("src", mapEmbedUrl);
            mapImage.classList.add("hidden");
            if (mapOverlay) mapOverlay.classList.add("hidden");
            if (mapPin) mapPin.classList.add("hidden");
          }

          const cta = document.getElementById("cta-primary");
          if (cta && settings.whatsapp_url) cta.setAttribute("href", settings.whatsapp_url);
        }
      }
    } catch (_) {
      // Keep static fallback content when PocketBase is unreachable.
    }

    try {
      const servicesRes = await fetch(`${baseUrl}/api/collections/services/records?page=1&perPage=12&sort=order&filter=is_active=true`);
      if (servicesRes.ok) {
        const servicesJson = await servicesRes.json();
        const items = servicesJson?.items || [];
        const grid = document.getElementById("services-grid");
        if (grid && items.length) {
          const cardClass = "group bg-white p-8 rounded-xl border border-outline-variant hover:border-tertiary-fixed-dim hover:shadow-xl transition-all duration-300 flex flex-col items-start gap-6";
          grid.innerHTML = "";

          items.forEach((service, index) => {
            const card = document.createElement("div");
            card.className = index === 1
              ? "group bg-primary text-white p-8 rounded-xl shadow-xl flex flex-col items-start gap-6 hover:scale-[1.02] transition-transform"
              : cardClass;

            const iconWrap = document.createElement("div");
            iconWrap.className = index === 1
              ? "w-14 h-14 bg-primary-container rounded-lg flex items-center justify-center"
              : "w-14 h-14 bg-surface-container-low rounded-lg flex items-center justify-center group-hover:bg-tertiary-fixed-dim transition-colors";

            const icon = document.createElement("span");
            icon.className = index === 1
              ? "material-symbols-outlined text-tertiary-fixed-dim"
              : "material-symbols-outlined text-primary group-hover:text-on-tertiary-fixed";
            icon.textContent = service.icon || "build";
            iconWrap.appendChild(icon);

            const title = document.createElement("h3");
            title.className = "font-headline-md text-headline-md" + (index === 1 ? "" : " text-on-surface");
            title.textContent = service.title || "Servicio";

            const desc = document.createElement("p");
            desc.className = index === 1
              ? "font-body-md text-body-md text-on-primary-container"
              : "font-body-md text-body-md text-on-surface-variant";
            desc.textContent = service.description || "";

            const more = document.createElement("div");
            more.className = index === 1
              ? "mt-auto pt-4 flex items-center text-tertiary-fixed-dim font-button gap-2"
              : "mt-auto pt-4 flex items-center text-primary font-button gap-2 group-hover:translate-x-2 transition-transform";
            more.innerHTML = 'Saber más <span class="material-symbols-outlined">arrow_forward</span>';

            card.appendChild(iconWrap);
            card.appendChild(title);
            card.appendChild(desc);
            card.appendChild(more);
            grid.appendChild(card);
          });
        }
      }
    } catch (_) {
      // Keep static fallback cards.
    }

    try {
      const galleryRes = await fetch(`${baseUrl}/api/collections/gallery/records?page=1&perPage=3&sort=order&filter=is_active=true`);
      if (!galleryRes.ok) return;
      const galleryJson = await galleryRes.json();
      const gallery = galleryJson?.items || [];
      const targets = ["gallery-image-1", "gallery-image-2", "gallery-image-3"];
      const activeSorted = gallery
        .filter((item) => item?.image)
        .sort((a, b) => Number(a.order || 0) - Number(b.order || 0));

      targets.forEach((targetId, idx) => {
        const img = document.getElementById(targetId);
        if (!img) return;
        const item = activeSorted[idx];
        const fallbackSrc = img.getAttribute("src");
        const fallbackAlt = img.getAttribute("alt");

        if (!item) {
          // Keep template fallback when there are fewer active gallery records.
          img.style.display = "";
          if (fallbackSrc) img.setAttribute("src", fallbackSrc);
          if (fallbackAlt) img.setAttribute("alt", fallbackAlt);
          return;
        }

        const src = mapImageUrl(baseUrl, "gallery", item.id, item.image);
        if (src) img.setAttribute("src", src);
        if (item.title) img.setAttribute("alt", item.title);
      });
    } catch (_) {
      // Keep static fallback gallery.
    }
  })();
</script>

